{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Backend: Glitter API",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/Glitter-api/app.js",
      "cwd": "${workspaceFolder}/Glitter-api",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Frontend: Vue App",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}/Glitter-Vue/src",
      "sourceMapPathOverrides": {
        "webpack:///src/*": "${webRoot}/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Fullstack: Backend + Frontend",
      "configurations": [
        "Backend: Glitter API",
        "Frontend: Vue App"
      ],
      "presentation": {
        "hidden": false,
        "group": "",
        "order": 1
      },
      "stopAll": true
    }
  ]
}

